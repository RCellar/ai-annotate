		{"id":"e1a0b2c3d4e50008","fromNode":"f1a0b2c3d4e50009","fromSide":"left","toNode":"f1a0b2c3d4e50004","toSide":"right","label":"config"},
		{"id":"e1a0b2c3d4e50009","fromNode":"f1a0b2c3d4e50009","fromSide":"left","toNode":"f1a0b2c3d4e50005","toSide":"right","label":"claudePath, model, timeout"},
		{"id":"e1a0b2c3d4e5000a","fromNode":"f1a0b2c3d4e5000a","fromSide":"right","toNode":"f1a0b2c3d4e50004","toSide":"left","label":"state transitions"},
		{"id":"e1a0b2c3d4e5000b","fromNode":"f1a0b2c3d4e50008","fromSide":"left","toNode":"f1a0b2c3d4e50004","toSide":"left","color":"1","label":"accept/reject"},
		{"id":"e1a0b2c3d4e5000c","fromNode":"f1a0b2c3d4e5000b","fromSide":"left","toNode":"f1a0b2c3d4e50008","toSide":"right","color":"4","label":"offset shifts"}
	]
}